# ============================================
# Bunny Siberian — Mock Environment Example
# ============================================
# Copie manualmente para .env se quiser testar
# com o mock server local.
#
# ATENCAO:
# - Mock NAO e producao
# - Dados SINTETICOS
# - Nao usar token real aqui
# - Nao commitar .env
# ============================================

BUNNY_SIBERIAN_API_URL=http://127.0.0.1:8890
BUNNY_SIBERIAN_API_TOKEN=mock-read-only-token
BUNNY_SIBERIAN_READ_ONLY=true
BUNNY_SIBERIAN_TIMEOUT=10

# Endpoint overrides (opcional, padrao ja funciona com mock)
BUNNY_SIBERIAN_ENDPOINT_COMPANIES=/api/companies
BUNNY_SIBERIAN_ENDPOINT_SALES=/api/sales
BUNNY_SIBERIAN_ENDPOINT_PRODUCTS=/api/products
BUNNY_SIBERIAN_ENDPOINT_STOCK=/api/stock
BUNNY_SIBERIAN_ENDPOINT_FINANCE=/api/finance
BUNNY_SIBERIAN_ENDPOINT_KPIS=/api/kpis
BUNNY_SIBERIAN_ENDPOINT_DASHBOARD=/api/dashboard
BUNNY_SIBERIAN_ENDPOINT_REPORTS=/api/reports
