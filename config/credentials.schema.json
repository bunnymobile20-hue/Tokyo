{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TokyoOS Credentials Schema",
  "description": "Schema for all TokyoOS environment variables and credentials",
  "type": "object",
  "properties": {
    "TOKYO_ENV": {
      "type": "string",
      "description": "Environment mode (zimaos, development, production)",
      "default": "zimaos",
      "enum": ["development", "production", "zimaos"]
    },
    "TOKYO_HOST": {
      "type": "string",
      "description": "Host to bind the server to",
      "default": "0.0.0.0"
    },
    "TOKYO_HTTP_PORT": {
      "type": "string",
      "description": "HTTP port for the server",
      "default": "8788"
    },
    "TOKYO_DATA_PATH": {
      "type": "string",
      "description": "ZimaOS volume path",
      "default": "/DATA/AppData/tokyoos"
    },
    "TOKYO_DATA_DIR": {
      "type": "string",
      "description": "Internal data directory",
      "default": "/data/tokyo"
    },
    "TOKYO_LOG_DIR": {
      "type": "string",
      "description": "Log directory",
      "default": "/data/tokyo/logs"
    },
    "TOKYO_SAFE_MODE": {
      "type": "string",
      "description": "Enable safe mode (blocks destructive operations)",
      "default": "true",
      "enum": ["true", "false"]
    },
    "TOKYO_TOKEN_EXPOSED": {
      "type": "string",
      "description": "If true, tokens are exposed in API responses (DANGER: only for debug)",
      "default": "false",
      "enum": ["true", "false"]
    },
    "TOKYO_AUTH_ENABLED": {
      "type": "string",
      "description": "Enable authentication",
      "default": "true"
    },
    "TOKYO_ADMIN_USER": {
      "type": "string",
      "description": "Admin username",
      "secret": true
    },
    "TOKYO_ADMIN_PASSWORD_HASH": {
      "type": "string",
      "description": "Hashed admin password (never plaintext)",
      "secret": true
    },
    "TOKYO_SESSION_SECRET": {
      "type": "string",
      "description": "Session encryption secret",
      "secret": true
    },
    "TOKYO_DEFAULT_LLM_PROVIDER": {
      "type": "string",
      "description": "Default LLM provider",
      "default": "gemini",
      "enum": ["gemini", "openai", "openai_compatible", "ollama", "openwebui"]
    },
    "TOKYO_FALLBACK_LLM_PROVIDER": {
      "type": "string",
      "description": "Fallback LLM provider",
      "default": "openai",
      "enum": ["gemini", "openai", "openai_compatible", "ollama", "openwebui"]
    },
    "LIVEKIT_URL": {
      "type": "string",
      "description": "LiveKit WebSocket URL",
      "secret": true
    },
    "LIVEKIT_API_KEY": {
      "type": "string",
      "description": "LiveKit API key",
      "secret": true
    },
    "LIVEKIT_API_SECRET": {
      "type": "string",
      "description": "LiveKit API secret",
      "secret": true
    },
    "GEMINI_API_KEY": {
      "type": "string",
      "description": "Google Gemini API key",
      "secret": true
    },
    "GEMINI_MODEL": {
      "type": "string",
      "description": "Gemini model name"
    },
    "OPENAI_API_KEY": {
      "type": "string",
      "description": "OpenAI API key",
      "secret": true
    },
    "OPENAI_MODEL": {
      "type": "string",
      "description": "OpenAI model name"
    },
    "OPENAI_COMPATIBLE_BASE_URL": {
      "type": "string",
      "description": "Base URL for OpenAI-compatible endpoint"
    },
    "OPENAI_COMPATIBLE_API_KEY": {
      "type": "string",
      "description": "API key for OpenAI-compatible endpoint",
      "secret": true
    },
    "OPENAI_COMPATIBLE_MODEL": {
      "type": "string",
      "description": "Model name for OpenAI-compatible endpoint"
    },
    "MEM0_API_KEY": {
      "type": "string",
      "description": "Mem0 API key",
      "secret": true
    },
    "OBSIDIAN_API_KEY": {
      "type": "string",
      "description": "Obsidian API key",
      "secret": true
    },
    "SIBERIAN_ENABLED": {
      "type": "string",
      "description": "Enable Siberian ERP connector",
      "default": "false"
    },
    "SIBERIAN_MODE": {
      "type": "string",
      "description": "Siberian connector mode",
      "default": "read_only",
      "enum": ["read_only", "read_write"]
    },
    "SIBERIAN_API_BASE_URL": {
      "type": "string",
      "description": "Siberian API base URL"
    },
    "SIBERIAN_API_KEY": {
      "type": "string",
      "description": "Siberian API key",
      "secret": true
    },
    "SIBERIAN_API_TOKEN": {
      "type": "string",
      "description": "Siberian API token",
      "secret": true
    }
  },
  "required": [
    "TOKYO_ENV",
    "TOKYO_HOST",
    "TOKYO_HTTP_PORT"
  ]
}
