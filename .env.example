# APPLE / MACOS AGENT — ECOSSISTEMA APPLE OPCIONAL

# ===========================================================================

APPLE_AGENT_ENABLED=false
APPLE_AGENT_BASE_URL=
APPLE_AGENT_API_KEY=
APPLE_AGENT_MODE=optional
APPLE_CALENDAR_ENABLED=false
APPLE_NOTES_ENABLED=false
APPLE_REMINDERS_ENABLED=false

