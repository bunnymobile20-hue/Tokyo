# ===========================================================================

# TOKYOOS — CORE APP

# ===========================================================================

TOKYO_ENV=zimaos
TOKYO_HOST=0.0.0.0
TOKYO_HTTP_PORT=8788
TOKYO_DATA_PATH=/DATA/AppData/tokyoos
TOKYO_DATA_DIR=/data/tokyo
TOKYO_LOG_DIR=/data/tokyo/logs
TOKYO_SAFE_MODE=true
TOKYO_OPERATION_MODE=company_operator
TOKYO_AUTOMATION_ENABLED=true
TOKYO_BROWSER_AUTOMATION_ENABLED=true
TOKYO_WEB_RESEARCH_ENABLED=true
TOKYO_WORKSPACE_WRITE_ENABLED=true
TOKYO_DOCUMENTS_ENABLED=true
TOKYO_SPREADSHEETS_ENABLED=true
TOKYO_LLM_PROVIDER=ollama
TOKYO_LLM_MODEL=qwen2.5:32b-instruct
TOKYO_HERMES_EXECUTOR=shim
TOKYO_DEMO_ONLY=false
TOKYO_DRY_RUN_ONLY=false
TOKYO_TOKEN_EXPOSED=false

# ===========================================================================

# TOKYOOS — LOGIN / ACESSO AO PAINEL

# ===========================================================================

# Preferir hash de senha em produção. Não salvar senha real no frontend.

TOKYO_AUTH_ENABLED=true
TOKYO_ADMIN_USER=
TOKYO_ADMIN_PASSWORD_HASH=
TOKYO_SESSION_SECRET=
TOKYO_ALLOWED_USERS=

# ===========================================================================

# LIVEKIT — VOICE AI / VOZ OFICIAL DA TOKYO

# ===========================================================================

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ===========================================================================

# GEMINI — GOOGLE AI / MOTOR LLM PRINCIPAL OPCIONAL

# ===========================================================================

GEMINI_API_KEY=
GEMINI_MODEL=

# ===========================================================================

# OPENAI — MOTOR LLM PRINCIPAL OPCIONAL

# ===========================================================================

OPENAI_API_KEY=
OPENAI_MODEL=

# ===========================================================================

# OPENAI-COMPATIBLE — ENDPOINT GENÉRICO

# Ex: OpenWebUI, Ollama proxy, LM Studio, llama.cpp server, Hermes provider etc.

# ===========================================================================

OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# ===========================================================================

# TOKYO LLM GATEWAY — ESCOLHA DO MOTOR PRINCIPAL

# ===========================================================================

TOKYO_DEFAULT_LLM_PROVIDER=gemini
TOKYO_DEFAULT_LLM_MODEL=
TOKYO_FALLBACK_LLM_PROVIDER=openai
TOKYO_LLM_TIMEOUT_SECONDS=60

# ===========================================================================

# MEMÓRIA — MEM0 / OBSIDIAN / MEMÓRIA LOCAL

# ===========================================================================

MEM0_ENABLED=false
MEM0_API_KEY=

OBSIDIAN_ENABLED=false
OBSIDIAN_API_KEY=
OBSIDIAN_VAULT_PATH=/data/tokyo/memory/obsidian

LOCAL_MEMORY_ENABLED=true
LOCAL_MEMORY_PATH=/data/tokyo/memory/local

BUNNY_INTELLIGENCE_ENABLED=true
BUNNY_INTELLIGENCE_PATH=/data/tokyo/intelligence

# ===========================================================================

# SISTEMA SIBERIAN — ERP PRINCIPAL DO GRUPSBUNNY

# Começar sempre em read_only.

# ===========================================================================

SIBERIAN_ENABLED=false
SIBERIAN_MODE=read_only
SIBERIAN_API_BASE_URL=
SIBERIAN_API_KEY=
SIBERIAN_API_TOKEN=
SIBERIAN_COMPANY_ID=
SIBERIAN_DEFAULT_STORE=

# Login web opcional, apenas se não houver API suficiente.

# Usar somente com autorização explícita e nunca expor no frontend.

SIBERIAN_WEB_LOGIN_URL=
SIBERIAN_WEB_USERNAME=
SIBERIAN_WEB_PASSWORD=
SIBERIAN_WEB_2FA_MODE=manual

# ===========================================================================

# BUNNY SIBERIAN — SISTEMAS / EMPRESA B2B

# ===========================================================================

BUNNY_SIBERIAN_ENABLED=false
BUNNY_SIBERIAN_MODE=read_only
BUNNY_SIBERIAN_API_BASE_URL=
BUNNY_SIBERIAN_API_KEY=
BUNNY_SIBERIAN_API_TOKEN=
BUNNY_SIBERIAN_WEB_LOGIN_URL=
BUNNY_SIBERIAN_WEB_USERNAME=
BUNNY_SIBERIAN_WEB_PASSWORD=
BUNNY_SIBERIAN_WEB_2FA_MODE=manual

# ===========================================================================

# HERMES — CONECTOR OPCIONAL

# Hermes não é obrigatório. Usar apenas como ferramenta externa integrada.

# ===========================================================================

TOKYO_HERMES_OPERATION_MODE=lab_unlocked
TOKYO_HERMES_REAL_AUTOMATION_ENABLED=true
TOKYO_HERMES_DEMO_ONLY=false
TOKYO_HERMES_SAFE_MODE=false
TOKYO_HERMES_PROVIDER=ollama
TOKYO_HERMES_MODEL=qwen2.5:32b-instruct
TOKYO_HERMES_OLLAMA_BASE_URL=http://192.168.1.173:11434
TOKYO_HERMES_OLLAMA_OPENAI_BASE_URL=http://192.168.1.173:11434/v1
TOKYO_HERMES_API_BASE_URL=http://192.168.1.173:9119
TOKYO_HERMES_BROWSER_ENABLED=true
TOKYO_HERMES_WEB_RESEARCH_ENABLED=true
TOKYO_HERMES_DOCUMENTS_ENABLED=true
TOKYO_HERMES_SPREADSHEETS_ENABLED=true
TOKYO_HERMES_APP_LAUNCH_ENABLED=true
TOKYO_HERMES_LOGIN_ASSISTED_ENABLED=true
TOKYO_HERMES_WORKSPACE_WRITE_ENABLED=true
TOKYO_HERMES_CREDENTIAL_CAPTURE_ENABLED=false
TOKYO_HERMES_EXPOSE_SECRETS=false
TOKYO_HERMES_DELETE_PROJECT_FILES=false

# ===========================================================================

# MCP — CONECTOR OPCIONAL

# MCP não é obrigatório. Será anexado depois como ferramenta.

# ===========================================================================

MCP_ENABLED=false
MCP_BASE_URL=
MCP_API_KEY=
MCP_MODE=optional
MCP_SAFE_MODE=true

# ===========================================================================

# OLLAMA / OPENWEBUI / LLAMA.CPP — LLM LOCAL OPCIONAL

# Não obrigatório na fase inicial.

# ===========================================================================

OLLAMA_ENABLED=false
OLLAMA_BASE_URL=
OLLAMA_DEFAULT_MODEL=

OPENWEBUI_ENABLED=false
OPENWEBUI_BASE_URL=
OPENWEBUI_API_KEY=
OPENWEBUI_DEFAULT_MODEL=

LLAMA_CPP_ENABLED=false
LLAMA_CPP_BASE_URL=
LLAMA_CPP_API_KEY=
LLAMA_CPP_DEFAULT_MODEL=

# ===========================================================================

# BROWSER USE / FIRECRAWL — AUTOMAÇÃO E PESQUISA WEB OPCIONAL

# ===========================================================================

BROWSER_USE_ENABLED=false
BROWSER_USE_BASE_URL=
BROWSER_USE_API_KEY=
BROWSER_USE_SAFE_MODE=true

FIRECRAWL_ENABLED=false
FIRECRAWL_BASE_URL=
FIRECRAWL_API_KEY=
FIRECRAWL_SAFE_MODE=true

# ===========================================================================

# OPENCLAW — AGENTE EXTERNO OPCIONAL

# ===========================================================================

OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_MODE=optional
OPENCLAW_SAFE_MODE=true

# ===========================================================================

# N8N — AUTOMAÇÕES OPCIONAIS

# ===========================================================================

N8N_ENABLED=false
N8N_BASE_URL=
N8N_API_KEY=
N8N_WEBHOOK_SECRET=

# ===========================================================================

# GOOGLE — CONECTORES OPCIONAIS

# ===========================================================================

GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIALS_PATH=
GOOGLE_CALENDAR_TOKEN_PATH=

GMAIL_ENABLED=false
GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=

GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CREDENTIALS_PATH=
GOOGLE_DRIVE_TOKEN_PATH=

