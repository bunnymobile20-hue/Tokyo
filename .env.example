# Exemplos de agentes futuros:

TOKYO_AGENT_MACBOOK_WALDYR_URL=
TOKYO_AGENT_PC_TERESINA_URL=
TOKYO_AGENT_PC_RIVERSIDE_URL=
TOKYO_AGENT_LAB_URL=

# ===========================================================================

# BANCOS / STORAGE / CACHE OPCIONAIS

# ===========================================================================

POSTGRES_ENABLED=false
POSTGRES_URL=

REDIS_ENABLED=false
REDIS_URL=

QDRANT_ENABLED=false
QDRANT_BASE_URL=
QDRANT_API_KEY=

CHROMA_ENABLED=false
CHROMA_BASE_URL=
CHROMA_API_KEY=

# ===========================================================================

# CREDENCIAIS WEB GENÉRICAS PARA SISTEMAS AUTORIZADOS

# Usar somente se API não existir e com autorização explícita.

# Não expor no frontend. Não registrar em logs.

# ===========================================================================

SYSTEM_1_ENABLED=false
SYSTEM_1_NAME=
SYSTEM_1_LOGIN_URL=
SYSTEM_1_USERNAME=
SYSTEM_1_PASSWORD=
SYSTEM_1_2FA_MODE=manual
SYSTEM_1_MODE=read_only

SYSTEM_2_ENABLED=false
SYSTEM_2_NAME=
SYSTEM_2_LOGIN_URL=
SYSTEM_2_USERNAME=
SYSTEM_2_PASSWORD=
SYSTEM_2_2FA_MODE=manual
SYSTEM_2_MODE=read_only

SYSTEM_3_ENABLED=false
SYSTEM_3_NAME=
SYSTEM_3_LOGIN_URL=
SYSTEM_3_USERNAME=
SYSTEM_3_PASSWORD=
SYSTEM_3_2FA_MODE=manual
SYSTEM_3_MODE=read_only

# ===========================================================================

# SEGURANÇA / SAFETY GATE

# ===========================================================================

SAFETY_GATE_ENABLED=true
SAFETY_REQUIRE_CONFIRMATION_FOR_WRITE=true
SAFETY_REQUIRE_CONFIRMATION_FOR_DELETE=true
SAFETY_REQUIRE_CONFIRMATION_FOR_FINANCE=true
SAFETY_REQUIRE_CONFIRMATION_FOR_STOCK=true
SAFETY_REQUIRE_CONFIRMATION_FOR_PRICE=true
SAFETY_MASK_SECRETS_IN_LOGS=true
SAFETY_BLOCK_SECRET_EXPOSURE=true

# ===========================================================================

# LOGS

# ===========================================================================

LOG_LEVEL=INFO
LOG_MASK_SECRETS=true
LOG_STORE_COMMAND_HISTORY=true
LOG_STORE_AGENT_ACTIONS=true
