#!/usr/bin/expect -f
set timeout 30
spawn ssh GrupsBunny@192.168.1.173
expect "password:"
send "32215820\r"
expect "GrupsBunny@ZimaOS"
send "mkdir -p /DATA/AppData/openjarvis-app\r"
expect "GrupsBunny@ZimaOS"
send "cat << 'YML' > /DATA/AppData/openjarvis-app/docker-compose.yml\nservices:\n  openjarvis:\n    build:\n      context: /DATA/AppData/.openjarvis/src\n      dockerfile: deploy/docker/Dockerfile\n    ports:\n      - \"8789:8000\"\n    environment:\n      - OPENJARVIS_ENGINE_DEFAULT=ollama\n      - OLLAMA_HOST=http://192.168.1.173:11434\n      - OPENJARVIS_API_KEY=tokyokey123\n    volumes:\n      - openjarvis-config:/home/openjarvis/.openjarvis\n    restart: unless-stopped\n\nvolumes:\n  openjarvis-config:\nYML\r"
expect "GrupsBunny@ZimaOS"
send "exit\r"
expect eof
